---------REMOTE DEHASHING---------

local randId = tostring(workspace:GetAttribute("RandId") or "")
local b64chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789"

local function decode(encoded)
    encoded = encoded:gsub("=", "")
    local bits = ""
    for i = 1, #encoded do
        local c = encoded:sub(i, i)
        local val = b64chars:find(c, 1, true) - 1
        for j = 5, 0, -1 do
            bits = bits .. (val % 2^(j+1) - val % 2^j > 0 and "1" or "0")
        end
    end
    local result = ""
    for i = 1, #bits - 7, 8 do
        local byte = 0
        for j = 0, 7 do
            byte = byte + (bits:sub(i+j, i+j) == "1" and 2^(7-j) or 0)
        end
        if byte ~= 0 then
            result = result .. string.char(byte)
        end
    end
    if result:sub(1, #randId) == randId then
        result = result:sub(#randId + 1)
    end
    return result
end

local netDir = game:GetService("ReplicatedStorage"):WaitForChild("SIMPLE_NET")
for _, v in ipairs(netDir:GetDescendants()) do
    local ok, decoded = pcall(decode, v.Name)
    if ok and decoded and #decoded > 0 then
        print("Dehashed", v.Name, "--->", decoded)
        v.Name = decoded
    end
end

